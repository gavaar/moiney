{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@convex/*": [
        "./convex/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "convex/**/*.ts",
    "convex/**/*.tsx",
    "nativewind-env.d.ts",
    "vitest.config.ts"
  ]
}